generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                Int               @id @default(autoincrement())
  email             String            @unique
  name              String?
  password          String
  role              UserRole          @default(CLIENT)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  orders            Order[]
  shippingAddresses ShippingAddress[]
  wishlist          Product[]         @relation("Wishlist")
  totalSpent        Decimal           @default(0) @db.Decimal(10, 2)
  ordersCount       Int               @default(0)
  lastLogin         DateTime?

  @@index([email])
}

model ShippingAddress {
  id              Int       @id @default(autoincrement())
  userId          Int
  address1        String
  address2        String?
  city            String
  state           String
  postalCode      String
  country         String
  isDefault       Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders          Order[]   @relation("ShippingAddressOrders")

  @@index([userId])
}

// Variant types for flexible product configurations
model VariantType {
  id        Int             @id @default(autoincrement())
  name      String          @unique            // e.g. "Size", "Color", etc.
  options   VariantOption[]
}

model VariantOption {
  id             Int               @id @default(autoincrement())
  variantType    VariantType       @relation(fields: [variantTypeId], references: [id])
  variantTypeId  Int
  value          String            // e.g. "S","M","L" or "Red","Blue"
  productOptions ProductOption[]
  selections     VariantSelection[]

  @@unique([variantTypeId, value])
}

model Brand {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  description String?
  logoUrl     String?
  website     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]

  @@index([name])
}

model Category {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  description String?
  imageUrl    String?   // one image per category
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]

  @@index([name])
}

model Tag {
  id          Int        @id @default(autoincrement())
  name        String     @unique
  color       String?
  products    Product[]  @relation("ProductTags")
}

model Product {
  id              Int               @id @default(autoincrement())
  name            String
  description     String?
  category        Category          @relation(fields: [categoryId], references: [id])
  categoryId      Int
  brand           Brand?            @relation(fields: [brandId], references: [id])
  brandId         Int?
  basePrice       Decimal           @db.Decimal(10, 2)
  status          Boolean           @default(true)
  featured        Boolean           @default(false)
  onSale          Boolean           @default(false)
  images          String[]          // Array of image URLs
  tags            Tag[]             @relation("ProductTags")
  allowedOptions  ProductOption[]   // which VariantOption values apply
  variants        ProductVariant[]  // specific SKU records
  wishlistedBy    User[]            @relation("Wishlist")
  orderItems      OrderItem[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([name])
  @@index([categoryId])
  @@index([brandId])
}

// which options a product can use
model ProductOption {
  id         Int            @id @default(autoincrement())
  product    Product        @relation(fields: [productId], references: [id])
  productId  Int
  option     VariantOption  @relation(fields: [optionId], references: [id])
  optionId   Int

  @@unique([productId, optionId])
}

// concrete product variants (SKUs)
model ProductVariant {
  id           Int               @id @default(autoincrement())
  product      Product           @relation(fields: [productId], references: [id])
  productId    Int
  sku          String            @unique
  price        Decimal           @db.Decimal(10, 2)
  stock        Int               @default(0)
  orderItems   OrderItem[]
  selections   VariantSelection[]  // which options compose this variant
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([productId])
}

// link table for productVariant -> variantOption
model VariantSelection {
  id         Int             @id @default(autoincrement())
  variant    ProductVariant  @relation(fields: [variantId], references: [id])
  variantId  Int
  option     VariantOption   @relation(fields: [optionId], references: [id])
  optionId   Int

  @@unique([variantId, optionId])
}



model Order {
  id                Int              @id @default(autoincrement())
  userId            Int?
  status            OrderStatus      @default(PENDING)
  total             Decimal          @db.Decimal(10, 2)
  shippingCost      Decimal          @db.Decimal(10, 2)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  customerEmail     String
  customerName      String
  customerPhone     String?
  notes             String?

  shippingAddressId Int?
  shippingAddress   ShippingAddress? @relation("ShippingAddressOrders", fields: [shippingAddressId], references: [id])

  shippingLine1     String?
  shippingLine2     String?
  shippingCity      String?
  shippingState     String?
  shippingPostal    String?
  shippingCountry   String?

  user              User?            @relation(fields: [userId], references: [id])
  orderItems        OrderItem[]

  @@index([userId])
  @@index([status])
  @@index([customerEmail])
}

model OrderItem {
  id               Int            @id @default(autoincrement())
  orderId          Int
  productId        Int
  productVariantId Int?
  quantity         Int
  price            Decimal        @db.Decimal(10, 2)
  productName      String
  productDetails   String?

  order            Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product          Product        @relation(fields: [productId], references: [id])
  productVariant   ProductVariant? @relation(fields: [productVariantId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@index([productVariantId])
}

model Settings {
  id           String   @id @default("main")
  siteTitle    String
  siteLogo     String?
  contactEmail String
  createdAt    DateTime @default(now())
  themeUrl     String
  updatedAt    DateTime @updatedAt
}

enum UserRole {
  CLIENT
  ADMIN
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}
